# Ingestion (запуск на хост-машине: uv run -m ingestion.pipeline ...)
QDRANT_URL=http://localhost:6333
EMBED_URL=http://localhost:8081
LLM_URL=http://localhost:8080

# GPU acceleration for llama.cpp containers
# Mac (Apple Silicon / Metal):
#   LLAMA_IMAGE_SUFFIX=-metal
#   GPU_LAYERS=99
#
# Windows / Linux (NVIDIA CUDA):
#   LLAMA_IMAGE_SUFFIX=-cuda
#   GPU_LAYERS=99
#
# CPU-only (default, no changes needed):
#   LLAMA_IMAGE_SUFFIX=
#   GPU_LAYERS=0
LLAMA_IMAGE_SUFFIX=
GPU_LAYERS=0
